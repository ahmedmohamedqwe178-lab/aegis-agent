# =============================================================
# AI Agent Pro - Environment Variables
# =============================================================
# ضع مفتاح واحد على الأقل. الوكيل يكتشف تلقائيًا أيهم متاح
# ويختار الأقوى بالترتيب: Anthropic > OpenAI > Groq > Ollama
# =============================================================

# 🥇 الأفضل للبرمجة - احصل عليه من https://console.anthropic.com
ANTHROPIC_API_KEY=

# 🥈 قوي ومتوازن - احصل عليه من https://platform.openai.com
OPENAI_API_KEY=

# 🥉 مجاني وسريع جداً! احصل عليه من https://console.groq.com/keys
GROQ_API_KEY=

# مجاني تاني - https://openrouter.ai/keys
OPENROUTER_API_KEY=

# اختياري: تشغيل موديل محلي عبر Ollama - https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# اختياري: توليد صور - https://platform.openai.com (يستخدم DALL-E 3)
# (نفس OPENAI_API_KEY السابق يكفي)

# اختياري: منفذ السيرفر
PORT=3000
